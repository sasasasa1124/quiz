{
  "name": "quiz",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postbuild": "rm -rf .vercel/output/functions/api/local-exams.func .vercel/output/functions/api/local-exams.rsc.func .vercel/output/functions/api/local-questions",
    "build:cf": "npx @cloudflare/next-on-pages",
    "preview": "npm run build:cf && wrangler pages dev",
    "start": "next start",
    "cf:setup": "wrangler d1 create quiz-db",
    "db:migrate": "wrangler d1 execute quiz-db --file=migrations/0001_init.sql",
    "db:migrate:local": "wrangler d1 execute quiz-db --local --file=migrations/0001_init.sql",
    "db:seed": "npx tsx scripts/seed-d1.ts",
    "db:seed:local": "npx tsx scripts/seed-d1.ts --local",
    "classify": "npx tsx scripts/classify-categories.ts",
    "classify:local": "npx tsx scripts/classify-categories.ts --local"
  },
  "dependencies": {
    "@google/genai": "^1.45.0",
    "@types/diff": "^7.0.2",
    "csv-parse": "^6.1.0",
    "diff": "^8.0.3",
    "lucide-react": "^0.577.0",
    "next": "^15.5.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.8.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@cloudflare/next-on-pages": "^1",
    "@cloudflare/workers-types": "^4",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "^4",
    "tsx": "^4",
    "typescript": "^5",
    "wrangler": "^3"
  }
}
